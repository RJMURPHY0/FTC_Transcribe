generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Folder {
  id         String      @id @default(cuid())
  name       String
  userId     String?
  createdAt  DateTime    @default(now())
  recordings Recording[]

  @@index([userId])
}

model Recording {
  id                 String    @id @default(cuid())
  title              String    @default("")
  createdAt          DateTime  @default(now())
  duration           Int       @default(0)
  fileSize           Int       @default(0)
  mimeType           String    @default("")
  audioPath          String    @default("")
  status             String    @default("uploading")
  source             String    @default("web")
  meetingType        String    @default("general")
  folderId           String?
  userId             String?
  // Soft delete: hidden from all lists immediately, hard-purged by cron after 30 days
  deletedAt          DateTime?
  // Idempotency stamps — each side effect fires at most once per recording
  teamsNotifiedAt    DateTime?
  airtableBackedUpAt DateTime?

  folder            Folder?            @relation(fields: [folderId], references: [id])
  chunks            ChunkBlob[]
  finalizeJob       FinalizeJob?
  transcript        Transcript?
  summary           Summary?
  speakerEmbeddings SpeakerEmbedding[]

  // deletedAt kept standalone for the 30-day purge cron (WHERE deletedAt < cutoff).
  // Composite indexes match the home/list query shape: scope by user/folder,
  // exclude soft-deleted, order by createdAt desc — so the planner can serve the
  // list straight from the index instead of scanning + sorting.
  @@index([deletedAt])
  @@index([userId, deletedAt, createdAt])
  @@index([folderId, deletedAt, createdAt])
  @@index([userId, source, deletedAt, createdAt])
}

// Mirrors auth.users — stores per-user Transcribe permission flags.
// Written by FTC Contacts super admin; read here to scope recording visibility.
model TranscribePermission {
  userId    String   @id @map("user_id")
  canSeeAll Boolean  @default(false) @map("can_see_all")
  grantedAt DateTime @default(now()) @map("granted_at")

  @@map("transcribe_permissions")
}

// Raw audio chunks stored during recording — transcribed in bulk at finalize time.
// Storing audio here (instead of transcribing inline) means the upload phase
// can never fail due to AI API errors, rate limits, or timeouts.
model ChunkBlob {
  id          String    @id @default(cuid())
  recordingId String
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  audioData   Bytes
  offset      Float     @default(0)
  mimeType    String    @default("audio/webm")
  // SHA-256 of the audio bytes — a partial unique index (raw DDL in
  // ensure-schema) rejects retry-duplicated chunks at the database level
  contentHash String    @default("")
  createdAt   DateTime  @default(now())

  @@index([recordingId, offset])
}

model FinalizeJob {
  id          String            @id @default(cuid())
  recordingId String            @unique
  recording   Recording         @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  status      String            @default("pending")
  attempts    Int               @default(0)
  lockToken   String?
  lockUntil   DateTime?
  lastError   String            @default("")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  chunks      ChunkTranscript[]

  @@index([status, updatedAt])
}

model ChunkTranscript {
  id          String      @id @default(cuid())
  jobId       String
  job         FinalizeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  recordingId String
  chunkId     String
  offset      Float       @default(0)
  status      String      @default("pending")
  attempts    Int         @default(0)
  lastError   String      @default("")
  transcript  String      @default("")
  segments    String      @default("[]")
  voiceData   String      @default("")
  processedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([jobId, chunkId])
  @@index([recordingId, status, offset])
  @@index([jobId, status])
}

model Transcript {
  id          String    @id @default(cuid())
  recordingId String    @unique
  recording   Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  fullText    String
  segments    String
  createdAt   DateTime  @default(now())
}

model Summary {
  id                 String    @id @default(cuid())
  recordingId        String    @unique
  recording          Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  overview           String
  keyPoints          String
  actionItems        String
  decisions          String
  topics             String    @default("[]")
  actionItemsChecked String    @default("[]")
  actionItemsDue     String    @default("[]")
  createdAt          DateTime  @default(now())
}

// Acoustic voice profiles — one row per enrollment phrase or relabel sample.
// embedding is a JSON array of 192 floats from the CAM++ speaker model.
model VoiceProfile {
  id          String   @id @default(cuid())
  userId      String?
  personName  String
  embedding   String
  durationS   Float    @default(0)
  source      String   @default("enrollment") // enrollment | relabel
  deviceLabel String   @default("")
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([personName])
}

// Per-recording global speaker voiceprints — powers matching + relearn-on-rename
model SpeakerEmbedding {
  id           String    @id @default(cuid())
  recordingId  String
  recording    Recording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  speakerLabel String
  embedding    String
  durationS    Float     @default(0)
  createdAt    DateTime  @default(now())

  @@index([recordingId])
}

// Speaker voice profiles — cross-recording speaker identification
model SpeakerProfile {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  features    String // JSON: { avgSegDuration, avgPause, speakingRate, topWords }
  sampleCount Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// Deduplication log for the auto-fix pipeline. One row per unique error
// message (hashed) within a 24-hour window — prevents 49 identical errors
// from spawning 49 PRs.
model AutoFixAttempt {
  id        String   @id @default(cuid())
  errorHash String
  errorMsg  String
  source    String   @default("")
  prUrl     String?
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@index([errorHash, createdAt])
}
